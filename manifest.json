{
  "manifest_version": 3,
  "name": "Homebase — New Tab Dashboard",
  "short_name": "Homebase",
  "version": "1.1.0",
  "description": "Replace new tab with your homebase.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
